---
const year = new Date().getFullYear();
---

<footer
  class="border-t mt-auto"
  style={`background-color: var(--bg-deep); border-color: var(--text-ghost);`}
>
  <div
    class="flex flex-col sm:flex-row items-center justify-between"
    style={`max-width: 1400px; margin: 0 auto; padding: 2rem 2.5rem; gap: 1rem;`}
  >
    <!-- Logo mark -->
    <span
      style={`font-family: var(--font-mono); font-weight: 500; color: var(--text-muted); font-size: var(--text-sm);`}
    >
      <span style={`color: var(--text-primary);`}>bt</span><span style={`color: var(--accent-primary);`}>sr</span> · {year}
    </span>

    <!-- Links -->
    <nav
      class="flex items-center gap-6"
      aria-label="Footer navigation"
    >
      <a
        href="https://www.linkedin.com/in/andy-rodrigue/"
        target="_blank"
        rel="noopener noreferrer"
        style={`color: var(--text-muted); display: flex; align-items: center; gap: 0.4rem; font-family: var(--font-sans); font-size: var(--text-sm);`}
        class="hover:no-underline transition-colors"
        aria-label="LinkedIn"
      >
        <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
        </svg>
        LinkedIn
      </a>
      <a
        href="https://github.com/andyje-dev"
        target="_blank"
        rel="noopener noreferrer"
        style={`color: var(--text-muted); display: flex; align-items: center; gap: 0.4rem; font-family: var(--font-sans); font-size: var(--text-sm);`}
        class="hover:no-underline transition-colors"
        aria-label="GitHub"
      >
        <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M12 0C5.374 0 0 5.373 0 12c0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23A11.509 11.509 0 0112 5.803c1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576C20.566 21.797 24 17.3 24 12c0-6.627-5.373-12-12-12z"/>
        </svg>
        GitHub
      </a>
      <a
        href="mailto:andy.rodrigue99@gmail.com"
        style={`color: var(--text-muted); display: flex; align-items: center; gap: 0.4rem; font-family: var(--font-sans); font-size: var(--text-sm);`}
        class="hover:no-underline transition-colors"
        aria-label="Contact"
      >
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <rect x="2" y="4" width="20" height="16" rx="2"/>
          <path d="M22 4L12 13 2 4"/>
        </svg>
        Contact
      </a>
      <a
        href="/feed"
        style={`color: var(--text-muted); display: flex; align-items: center; gap: 0.4rem; font-family: var(--font-sans); font-size: var(--text-sm);`}
        class="hover:no-underline transition-colors"
        aria-label="RSS Feed"
      >
        <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <circle cx="6.18" cy="17.82" r="2.18"/>
          <path d="M4 4.44v2.83c7.03 0 12.73 5.7 12.73 12.73h2.83c0-8.59-6.97-15.56-15.56-15.56zm0 5.66v2.83c3.9 0 7.07 3.17 7.07 7.07h2.83c0-5.47-4.43-9.9-9.9-9.9z"/>
        </svg>
        RSS
      </a>
    </nav>
  </div>
</footer>
