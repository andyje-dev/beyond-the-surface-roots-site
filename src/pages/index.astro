---
import BaseLayout from "../layouts/BaseLayout.astro";
import ContentCard from "../components/content/ContentCard.astro";
import ContentGrid from "../components/content/ContentGrid.astro";
import { getCollection } from "astro:content";
import { estimateReadingTime } from "../utils/reading-time";

const curation = await getCollection("curation");

const allContent = [
  ...curation.map((entry) => ({
    ...entry,
    type: "brief" as const,
    href: `/curation/${entry.id}`,
  })),
].sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

const featured = allContent.find((c) => c.data.featured);
const recent = allContent.filter((c) => c !== featured).slice(0, 6);
---

<BaseLayout>
  <!-- Hero -->
  <section
    class="flex flex-col items-center px-6"
    style={`padding-top: 7rem; padding-bottom: 4rem;`}
  >
    <h1
      style={`font-size: clamp(2rem, 5vw, 2.75rem); line-height: 1.15; text-align: center; margin-bottom: 4rem;`}
    >
      beyond the{" "}
      <span style={`color: var(--accent-primary);`}>surface roots</span>
    </h1>
    <p
      style={`max-width: var(--max-width-prose); font-size: var(--text-lg); color: var(--text-secondary); line-height: 1.8; text-align: center;`}
    >
      Discover at the intersection of technology, nature, design, and policy.
    </p>
  </section>

  <!-- CTA -->
  <section class="flex justify-center" style={`padding-bottom: 2rem;`}>
    <a
      href="/exploration"
      class="inline-flex items-center gap-2 no-underline hover:no-underline"
      style={`
        font-family: var(--font-sans);
        font-weight: 500;
        font-size: var(--text-sm);
        color: var(--bg-void);
        background-color: var(--accent-primary);
        padding: 0.75rem 1.5rem;
        border-radius: var(--radius-md);
        transition: opacity 0.2s;
      `}
    >
      Explore
      <span aria-hidden="true">&rarr;</span>
    </a>
  </section>

  <!-- Wave pattern -->
  <section class="overflow-hidden" style={`opacity: 0.3;`}>
    <svg
      viewBox="0 0 1600 300"
      preserveAspectRatio="none"
      class="w-full"
      style={`height: 180px;`}
      aria-hidden="true"
    >
      <path
        d="M0,150 C270,30 530,270 800,150 C1070,30 1330,270 1600,150"
        fill="none"
        stroke="var(--accent-primary)"
        stroke-width="2"
      >
        <animate
          attributeName="d"
          values="M0,150 C270,30 530,270 800,150 C1070,30 1330,270 1600,150;
                  M0,140 C270,50 530,250 800,160 C1070,50 1330,250 1600,140;
                  M0,160 C270,20 530,280 800,140 C1070,20 1330,280 1600,160;
                  M0,150 C270,30 530,270 800,150 C1070,30 1330,270 1600,150"
          dur="12s"
          repeatCount="indefinite"
        />
      </path>
      <path
        d="M0,120 C270,260 530,10 800,120 C1070,260 1330,10 1600,120"
        fill="none"
        stroke="var(--domain-quantum)"
        stroke-width="2"
      >
        <animate
          attributeName="d"
          values="M0,120 C270,260 530,10 800,120 C1070,260 1330,10 1600,120;
                  M0,130 C270,240 530,30 800,110 C1070,240 1330,30 1600,130;
                  M0,110 C270,270 530,0 800,130 C1070,270 1330,0 1600,110;
                  M0,120 C270,260 530,10 800,120 C1070,260 1330,10 1600,120"
          dur="15s"
          repeatCount="indefinite"
        />
      </path>
      <path
        d="M0,180 C270,50 530,240 800,180 C1070,50 1330,240 1600,180"
        fill="none"
        stroke="var(--domain-climate)"
        stroke-width="2"
      >
        <animate
          attributeName="d"
          values="M0,180 C270,50 530,240 800,180 C1070,50 1330,240 1600,180;
                  M0,170 C270,70 530,220 800,190 C1070,70 1330,220 1600,170;
                  M0,190 C270,40 530,250 800,170 C1070,40 1330,250 1600,190;
                  M0,180 C270,50 530,240 800,180 C1070,50 1330,240 1600,180"
          dur="18s"
          repeatCount="indefinite"
        />
      </path>
      <path
        d="M0,170 C270,300 530,40 800,170 C1070,300 1330,40 1600,170"
        fill="none"
        stroke="var(--domain-design)"
        stroke-width="2"
      >
        <animate
          attributeName="d"
          values="M0,170 C270,300 530,40 800,170 C1070,300 1330,40 1600,170;
                  M0,160 C270,280 530,50 800,165 C1070,280 1330,50 1600,160;
                  M0,180 C270,310 530,30 800,175 C1070,310 1330,30 1600,180;
                  M0,170 C270,300 530,40 800,170 C1070,300 1330,40 1600,170"
          dur="14s"
          repeatCount="indefinite"
        />
      </path>
      <path
        d="M0,100 C270,220 530,-20 800,100 C1070,220 1330,-20 1600,100"
        fill="none"
        stroke="var(--domain-architecture)"
        stroke-width="2"
      >
        <animate
          attributeName="d"
          values="M0,100 C270,220 530,-20 800,100 C1070,220 1330,-20 1600,100;
                  M0,110 C270,210 530,0 800,105 C1070,210 1330,0 1600,110;
                  M0,90 C270,230 530,-30 800,95 C1070,230 1330,-30 1600,90;
                  M0,100 C270,220 530,-20 800,100 C1070,220 1330,-20 1600,100"
          dur="16s"
          repeatCount="indefinite"
        />
      </path>
      <path
        d="M0,200 C270,80 530,320 800,200 C1070,80 1330,320 1600,200"
        fill="none"
        stroke="var(--domain-iot)"
        stroke-width="2"
      >
        <animate
          attributeName="d"
          values="M0,200 C270,80 530,320 800,200 C1070,80 1330,320 1600,200;
                  M0,190 C270,90 530,300 800,195 C1070,90 1330,300 1600,190;
                  M0,210 C270,70 530,330 800,205 C1070,70 1330,330 1600,210;
                  M0,200 C270,80 530,320 800,200 C1070,80 1330,320 1600,200"
          dur="20s"
          repeatCount="indefinite"
        />
      </path>
      <path
        d="M0,130 C270,260 530,0 800,130 C1070,260 1330,0 1600,130"
        fill="none"
        stroke="var(--domain-culture)"
        stroke-width="2"
      >
        <animate
          attributeName="d"
          values="M0,130 C270,260 530,0 800,130 C1070,260 1330,0 1600,130;
                  M0,120 C270,240 530,10 800,125 C1070,240 1330,10 1600,120;
                  M0,140 C270,270 530,-10 800,135 C1070,270 1330,-10 1600,140;
                  M0,130 C270,260 530,0 800,130 C1070,260 1330,0 1600,130"
          dur="17s"
          repeatCount="indefinite"
        />
      </path>
      <path
        d="M0,90 C270,-20 530,200 800,90 C1070,-20 1330,200 1600,90"
        fill="none"
        stroke="var(--domain-human-rights)"
        stroke-width="2"
      >
        <animate
          attributeName="d"
          values="M0,90 C270,-20 530,200 800,90 C1070,-20 1330,200 1600,90;
                  M0,100 C270,0 530,190 800,95 C1070,0 1330,190 1600,100;
                  M0,80 C270,-30 530,210 800,85 C1070,-30 1330,210 1600,80;
                  M0,90 C270,-20 530,200 800,90 C1070,-20 1330,200 1600,90"
          dur="19s"
          repeatCount="indefinite"
        />
      </path>
      <path
        d="M0,210 C270,330 530,90 800,210 C1070,330 1330,90 1600,210"
        fill="none"
        stroke="var(--domain-policy)"
        stroke-width="2"
      >
        <animate
          attributeName="d"
          values="M0,210 C270,330 530,90 800,210 C1070,330 1330,90 1600,210;
                  M0,200 C270,310 530,100 800,205 C1070,310 1330,100 1600,200;
                  M0,220 C270,340 530,80 800,215 C1070,340 1330,80 1600,220;
                  M0,210 C270,330 530,90 800,210 C1070,330 1330,90 1600,210"
          dur="21s"
          repeatCount="indefinite"
        />
      </path>
      <path
        d="M0,140 C270,20 530,260 800,140 C1070,20 1330,260 1600,140"
        fill="none"
        stroke="var(--domain-agriculture)"
        stroke-width="2"
      >
        <animate
          attributeName="d"
          values="M0,140 C270,20 530,260 800,140 C1070,20 1330,260 1600,140;
                  M0,135 C270,30 530,240 800,135 C1070,30 1330,240 1600,135;
                  M0,145 C270,10 530,280 800,145 C1070,10 1330,280 1600,145;
                  M0,140 C270,20 530,260 800,140 C1070,20 1330,260 1600,140"
          dur="13s"
          repeatCount="indefinite"
        />
      </path>
      <path
        d="M0,190 C270,310 530,70 800,190 C1070,310 1330,70 1600,190"
        fill="none"
        stroke="var(--domain-education)"
        stroke-width="2"
      >
        <animate
          attributeName="d"
          values="M0,190 C270,310 530,70 800,190 C1070,310 1330,70 1600,190;
                  M0,185 C270,290 530,80 800,185 C1070,290 1330,80 1600,185;
                  M0,195 C270,320 530,60 800,195 C1070,320 1330,60 1600,195;
                  M0,190 C270,310 530,70 800,190 C1070,310 1330,70 1600,190"
          dur="22s"
          repeatCount="indefinite"
        />
      </path>
    </svg>
  </section>

  <!-- Featured -->
  {featured && (
    <section
      style={`max-width: 1400px; margin: 0 auto; padding: 5rem 2.5rem 3rem;`}
    >
      <h2 style={`font-size: var(--text-2xl); margin-bottom: 2rem;`}>Featured</h2>
      <ContentGrid>
        <ContentCard
          title={featured.data.title}
          description={featured.data.description}
          href={featured.href}
          domains={featured.data.domains}

          date={featured.data.date}
          type={featured.type}
          readingTime={estimateReadingTime(featured.body ?? "")}
        />
      </ContentGrid>
    </section>
  )}

  <!-- Recent -->
  <section
    style={`max-width: 1400px; margin: 0 auto; padding: 3rem 2.5rem 6rem;`}
  >
    <h2 style={`font-size: var(--text-2xl); margin-bottom: 2rem;`}>Recent</h2>
    <ContentGrid>
      {recent.map((entry) => (
        <ContentCard
          title={entry.data.title}
          description={entry.data.description}
          href={entry.href}
          domains={entry.data.domains}

          date={entry.data.date}
          type={entry.type}
          readingTime={estimateReadingTime(entry.body ?? "")}
        />
      ))}
    </ContentGrid>
  </section>
</BaseLayout>
