---
import Nav from "../components/layout/Nav.astro";
import Footer from "../components/layout/Footer.astro";
import "../styles/global.css";

interface Props {
  title?: string;
  description?: string;
}

const { title, description } = Astro.props;
const siteTitle = title ? `${title} — btsr` : "btsr";
const siteDescription =
  description ??
  "Exploring the intersection of quantum computing and pressing global challenges.";
---

<!doctype html>
<html lang="en" data-theme="dark">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={siteDescription} />
    <meta name="generator" content={Astro.generator} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/png" sizes="192x192" href="/icons/btsr-192x192.png" />
    <link rel="apple-touch-icon" href="/icons/btsr-apple-touch-icon.png" />
    <link rel="manifest" href="/site.webmanifest" />
    <meta name="theme-color" content="#0C0F0A" />

    <!-- RSS -->
    <link rel="alternate" type="application/rss+xml" title="btsr" href="/rss.xml" />

    <!-- Analytics — Plausible (privacy-friendly, no cookies) -->
    <script is:inline src="https://plausible.io/js/script.js" defer data-domain="beyond-the-surface-roots.com"></script>

    <!-- Preload critical fonts -->
    <link
      rel="preload"
      href="https://fonts.gstatic.com/s/ibmplexmono/v19/-F6qfjptAgt5VM-kVkqdyU8n3oQI.woff2"
      as="font"
      type="font/woff2"
      crossorigin
    />
    <link
      rel="preload"
      href="https://fonts.gstatic.com/s/ibmplexserif/v19/jizDREVNn1dOx-zrZ2X3pZvkTiU.woff2"
      as="font"
      type="font/woff2"
      crossorigin
    />

    <title>{siteTitle}</title>

    <!-- Theme initialization — runs before paint to prevent flash -->
    <script is:inline>
      (function () {
        const stored = localStorage.getItem("theme");
        const preferred = window.matchMedia("(prefers-color-scheme: light)")
          .matches
          ? "light"
          : "dark";
        document.documentElement.setAttribute(
          "data-theme",
          stored || preferred,
        );
      })();
    </script>
  </head>
  <body style="min-height: 100dvh; display: flex; flex-direction: column;">
    <a href="#main-content" class="skip-to-content">Skip to content</a>
    <Nav />
    <main id="main-content" style="flex: 1;">
      <slot />
    </main>
    <Footer />
  </body>
</html>
