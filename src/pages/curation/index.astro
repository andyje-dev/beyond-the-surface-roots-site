---
import BaseLayout from "../../layouts/BaseLayout.astro";
import FilterableCardGrid from "../../components/content/FilterableCardGrid.tsx";
import { getCollection } from "astro:content";
import { estimateReadingTime } from "../../utils/reading-time";
import { domains } from "../../config/domains";

const curation = await getCollection("curation");

const allEntries = [
  ...curation.map((entry) => ({
    title: entry.data.title,
    description: entry.data.description,
    href: `/curation/${entry.id}`,
    domains: entry.data.domains,
    date: entry.data.date.toISOString(),
    type: "brief" as const,
    readingTime: estimateReadingTime(entry.body ?? ""),
  })),
].sort((a, b) => new Date(b.date).getTime() - new Date(a.date).getTime());

// Count articles per domain
const domainCounts = new Map<string, number>();
for (const entry of allEntries) {
  for (const d of entry.domains) {
    domainCounts.set(d, (domainCounts.get(d) || 0) + 1);
  }
}

const domainInfo = domains.map((d) => ({
  id: d.id,
  label: d.label,
  colorDark: d.color.dark,
  colorLight: d.color.light,
  count: domainCounts.get(d.id) || 0,
}));
---

<BaseLayout title="Curation" description="Connecting current research across domains.">
  <section
    style={`max-width: 1400px; margin: 0 auto; padding: 5rem 2.5rem 6rem;`}
  >
    <h1 class="fade-up" style={`font-size: var(--text-3xl); margin-bottom: 1rem;`}>Curation</h1>
    <p class="fade-up fade-up-delay-1" style={`color: var(--text-secondary); max-width: 680px; margin-bottom: 3rem;`}>
      Connecting current research across domains.
    </p>

    <FilterableCardGrid
      client:only="react"
      entries={allEntries}
      domains={domainInfo}
    />
  </section>
</BaseLayout>
