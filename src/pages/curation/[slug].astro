---
import BaseLayout from "../../layouts/BaseLayout.astro";
import DomainTags from "../../components/content/DomainTags.astro";
import { getCollection, render } from "astro:content";
import { estimateReadingTime } from "../../utils/reading-time";

export async function getStaticPaths() {
  const curation = await getCollection("curation");

  return [
    ...curation.map((entry) => ({
      params: { slug: entry.id },
      props: { entry, type: "brief" as const },
    })),
  ];
}

const { entry, type } = Astro.props;
const { Content } = await render(entry);
const readingTime = estimateReadingTime(entry.body ?? "");
const formattedDate = entry.data.date.toLocaleDateString("en-US", {
  month: "long",
  day: "numeric",
  year: "numeric",
});
---

<BaseLayout title={entry.data.title} description={entry.data.description}>
  <article style={`max-width: 680px; margin: 0 auto; padding: 4rem 2rem 6rem;`}>
    <!-- Header -->
    <header class="fade-up" style={`margin-bottom: 3rem;`}>
      <a
        href="/curation"
        class="no-underline hover:no-underline"
        style={`
          font-family: var(--font-sans);
          font-size: 0.8125rem;
          color: var(--text-muted);
          display: inline-flex;
          align-items: center;
          gap: 0.4rem;
          margin-bottom: 2rem;
        `}
      >
        ← Back to curation
      </a>

      <h1
        style={`
          font-family: var(--font-mono);
          font-weight: 500;
          font-size: clamp(1.5rem, 4vw, 2.25rem);
          line-height: 1.2;
          color: var(--text-primary);
          margin-bottom: 1.25rem;
        `}
      >
        {entry.data.title}
      </h1>

      <div
        class="flex flex-wrap items-center"
        style={`gap: 1rem; margin-bottom: 1.25rem;`}
      >
        <DomainTags domains={entry.data.domains} />
      </div>

      <div
        style={`
          font-family: var(--font-mono);
          font-size: 0.75rem;
          color: var(--text-muted);
          display: flex;
          align-items: center;
          gap: 0.5rem;
        `}
      >
        <span>{type}</span>
        <span aria-hidden="true">·</span>
        <span>{readingTime} min read</span>
        <span aria-hidden="true">·</span>
        <time datetime={entry.data.date.toISOString()}>{formattedDate}</time>
      </div>
    </header>

    <!-- Sources (research briefs only) -->
    {entry.data.sources && entry.data.sources.length > 0 && (
      <aside
        style={`
          border: 1px solid var(--text-ghost);
          border-radius: 8px;
          padding: 1.25rem;
          margin-bottom: 2.5rem;
          background-color: var(--bg-surface);
        `}
      >
        <h2
          style={`
            font-family: var(--font-mono);
            font-size: 0.8125rem;
            font-weight: 500;
            color: var(--text-muted);
            margin-bottom: 0.75rem;
          `}
        >
          Sources
        </h2>
        <ul style={`list-style: none; display: flex; flex-direction: column; gap: 0.5rem;`}>
          {entry.data.sources.map((source: any) => (
            <li style={`font-size: 0.8125rem; line-height: 1.5;`}>
              <a
                href={source.url}
                target="_blank"
                rel="noopener noreferrer"
                style={`color: var(--accent-primary);`}
              >
                {source.title}
              </a>
              <span style={`color: var(--text-muted);`}>
                {" "}— {source.authors}{source.journal ? `, ${source.journal}` : ""} ({source.year})
              </span>
            </li>
          ))}
        </ul>
      </aside>
    )}

    <!-- Body -->
    <div class="prose-content fade-up">
      <Content />
    </div>
  </article>
</BaseLayout>

<style is:global>
  .prose-content {
    font-family: var(--font-serif);
    font-size: 1.0625rem;
    line-height: 1.8;
    color: var(--text-secondary);
  }

  .prose-content h2 {
    font-family: var(--font-mono);
    font-weight: 500;
    font-size: 1.375rem;
    color: var(--text-primary);
    margin-top: 3rem;
    margin-bottom: 1rem;
    line-height: 1.3;
  }

  .prose-content h3 {
    font-family: var(--font-mono);
    font-weight: 500;
    font-size: 1.125rem;
    color: var(--text-primary);
    margin-top: 2.5rem;
    margin-bottom: 0.75rem;
    line-height: 1.35;
  }

  .prose-content p {
    margin-bottom: 1.5rem;
  }

  .prose-content strong {
    font-weight: 500;
    color: var(--text-primary);
  }

  .prose-content em {
    font-style: italic;
  }

  .prose-content a {
    color: var(--accent-primary);
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  .prose-content ul,
  .prose-content ol {
    margin-bottom: 1.5rem;
    padding-left: 1.5rem;
  }

  .prose-content ul {
    list-style-type: disc;
  }

  .prose-content ol {
    list-style-type: decimal;
  }

  .prose-content li {
    margin-bottom: 0.5rem;
  }

  .prose-content pre {
    background-color: var(--bg-deep);
    border: 1px solid var(--text-ghost);
    border-radius: 8px;
    padding: 1.25rem;
    overflow-x: auto;
    margin-bottom: 1.5rem;
    font-family: var(--font-mono);
    font-size: 0.8125rem;
    line-height: 1.6;
  }

  .prose-content code {
    font-family: var(--font-mono);
    font-size: 0.875em;
    background-color: var(--bg-deep);
    padding: 0.15em 0.4em;
    border-radius: 4px;
  }

  .prose-content pre code {
    background: none;
    padding: 0;
    border-radius: 0;
    font-size: inherit;
  }

  .prose-content blockquote {
    border-left: 3px solid var(--accent-primary);
    padding-left: 1.25rem;
    margin-bottom: 1.5rem;
    color: var(--text-muted);
    font-style: italic;
  }

  .prose-content hr {
    border: none;
    border-top: 1px solid var(--text-ghost);
    margin: 3rem 0;
  }
</style>
