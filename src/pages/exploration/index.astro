---
import BaseLayout from "../../layouts/BaseLayout.astro";
import NetworkGraph from "../../components/exploration/NetworkGraph.tsx";
import { domains } from "../../config/domains";

const domainInfo = domains.map((d) => ({
  id: d.id,
  label: d.label,
  colorDark: d.color.dark,
  colorLight: d.color.light,
  description: d.description,
  count: 0,
}));
---

<BaseLayout title="Exploration" description="Visualize connections across research domains.">
  <section
    style={`max-width: 1400px; margin: 0 auto; padding: 5rem 2.5rem 6rem;`}
  >
    <h1 class="fade-up" style={`font-size: var(--text-3xl); margin-bottom: 1rem;`}>Exploration</h1>
    <p class="fade-up fade-up-delay-1" style={`color: var(--text-secondary); max-width: 680px; margin-bottom: 3rem;`}>
      A living map of how ideas connect. Drag to rearrange, scroll to zoom, click to read.
    </p>

    <NetworkGraph
      client:only="react"
      nodes={[]}
      links={[]}
      domains={domainInfo}
    />
  </section>
</BaseLayout>
