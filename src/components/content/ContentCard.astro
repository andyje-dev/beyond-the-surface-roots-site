---
import IntersectionBar from "./IntersectionBar.astro";
import DomainTags from "./DomainTags.astro";
interface Props {
  title: string;
  description: string;
  href: string;
  domains: string[];
  date: Date;
  type: "brief" | "essay" | "exploration";
  readingTime?: number;
}

const { title, description, href, domains, date, type, readingTime } =
  Astro.props;

const formattedDate = date.toLocaleDateString("en-US", {
  month: "short",
  year: "numeric",
});
---

<article
  style={`
    background-color: var(--bg-surface);
    border: 1px solid var(--text-ghost);
    border-radius: 8px;
    overflow: hidden;
    transition: transform 0.2s, border-color 0.2s;
  `}
  class="content-card"
>
  <IntersectionBar domains={domains} />
  <a
    href={href}
    class="no-underline hover:no-underline"
    style={`display: block; padding: 1.25rem;`}
  >
    <h3
      style={`
        font-family: var(--font-mono);
        font-weight: 500;
        font-size: 0.95rem;
        color: var(--text-primary);
        margin-bottom: 0.5rem;
        line-height: 1.4;
      `}
    >
      {title}
    </h3>
    <p
      style={`
        font-family: var(--font-serif);
        font-size: 0.875rem;
        color: var(--text-secondary);
        line-height: 1.5;
        margin-bottom: 1rem;
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
      `}
    >
      {description}
    </p>

    <DomainTags domains={domains} />

    <div
      class="flex items-center"
      style={`
        gap: 0.5rem;
        margin-top: 0.75rem;
        font-family: var(--font-mono);
        font-size: 0.6875rem;
        color: var(--text-muted);
      `}
    >
      <span>{type}</span>
      {readingTime && (
        <>
          <span aria-hidden="true">·</span>
          <span>{readingTime} min</span>
        </>
      )}
      <span aria-hidden="true">·</span>
      <time datetime={date.toISOString()}>{formattedDate}</time>
    </div>
  </a>
</article>

<style is:global>
  .content-card:hover {
    transform: translateY(-2px);
    border-color: var(--text-muted) !important;
  }

  @media (prefers-reduced-motion: reduce) {
    .content-card:hover {
      transform: none;
    }
  }
</style>
