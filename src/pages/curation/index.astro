---
import BaseLayout from "../../layouts/BaseLayout.astro";
---

<BaseLayout title="Curation" description="Connecting current research across domains.">
  <section
    style="max-width: 1400px; margin: 0 auto; padding: 5rem 2.5rem 6rem;"
  >
    <h1 class="fade-up" style="font-size: var(--text-3xl); margin-bottom: 1rem;">Curation</h1>
    <p class="fade-up fade-up-delay-1" style="color: var(--text-secondary); max-width: 680px; margin-bottom: 3rem;">
      Connecting current research across domains.
    </p>

    <div class="fade-up fade-up-delay-2" style="display: flex; justify-content: center; padding: 4rem 0;">
      <div style="max-width: 480px; width: 100%; border: 1px solid var(--text-ghost); border-radius: 8px; padding: 3rem 2rem; text-align: center; background: var(--bg-surface);">
        <div style="font-family: var(--font-mono); font-size: 2rem; margin-bottom: 1rem; color: var(--accent-primary);">
          &#x1F331;
        </div>
        <h2 style="font-family: var(--font-mono); font-size: var(--text-lg); margin-bottom: 0.75rem; color: var(--text-primary);">
          Coming Soon
        </h2>
        <p style="font-family: var(--font-serif); color: var(--text-secondary); line-height: 1.6; font-size: var(--text-sm);">
          Research briefs and essays are being curated. Check back soon for writing at the intersection of technology, nature, design, and policy.
        </p>
      </div>
    </div>
  </section>
</BaseLayout>
