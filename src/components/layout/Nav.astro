---
import { nav } from "../../config/site";
import ThemeToggle from "./ThemeToggle.tsx";

const currentPath = Astro.url.pathname;
---

<header
  class="sticky top-0 z-50 border-b"
  style={`background-color: var(--bg-deep); border-color: var(--text-ghost);`}
>
  <nav
    class="flex items-center justify-between"
    style={`max-width: 1400px; margin: 0 auto; padding: 1rem 2.5rem;`}
    aria-label="Primary navigation"
  >
    <!-- Logo -->
    <a
      href="/"
      class="flex items-center gap-2 no-underline hover:no-underline"
      style={`color: var(--accent-primary); font-family: var(--font-mono); font-weight: 500; font-size: var(--text-xl);`}
    >
      <svg width="22" height="22" viewBox="0 0 24 24" fill="none" aria-hidden="true" style="flex-shrink: 0;">
        <!-- Central node -->
        <circle cx="12" cy="12" r="1.5" fill="var(--accent-primary)" />
        <!-- Main stem down -->
        <path d="M12 13.5 L12 17" stroke="var(--accent-primary)" stroke-width="1.4" stroke-linecap="round" />
        <!-- Lower branches -->
        <path d="M12 17 L7.5 22" stroke="var(--accent-primary)" stroke-width="1.2" stroke-linecap="round" />
        <path d="M12 17 L16.5 22.5" stroke="var(--accent-primary)" stroke-width="1.1" stroke-linecap="round" />
        <path d="M12 17 L12.5 23" stroke="var(--accent-primary)" stroke-width="0.9" stroke-linecap="round" />
        <path d="M9.5 19.5 L5.5 20.5" stroke="var(--accent-primary)" stroke-width="0.8" stroke-linecap="round" />
        <path d="M14.5 20 L18 20.5" stroke="var(--accent-primary)" stroke-width="0.7" stroke-linecap="round" />
        <path d="M7.5 22 L5 23" stroke="var(--accent-primary)" stroke-width="0.6" stroke-linecap="round" />
        <path d="M16.5 22.5 L19 23.5" stroke="var(--accent-primary)" stroke-width="0.6" stroke-linecap="round" />
        <!-- Main stem up -->
        <path d="M12 10.5 L12 7" stroke="var(--accent-primary)" stroke-width="1.3" stroke-linecap="round" />
        <!-- Upper branches -->
        <path d="M12 7 L8.5 3.5" stroke="var(--accent-primary)" stroke-width="1.1" stroke-linecap="round" />
        <path d="M12 7 L16 3" stroke="var(--accent-primary)" stroke-width="1" stroke-linecap="round" />
        <path d="M12 7 L11 2" stroke="var(--accent-primary)" stroke-width="0.8" stroke-linecap="round" />
        <path d="M8.5 3.5 L6 2" stroke="var(--accent-primary)" stroke-width="0.7" stroke-linecap="round" />
        <path d="M16 3 L19 1.5" stroke="var(--accent-primary)" stroke-width="0.7" stroke-linecap="round" />
        <path d="M10 5 L7 5.5" stroke="var(--accent-primary)" stroke-width="0.7" stroke-linecap="round" />
        <path d="M14 5 L16.5 6" stroke="var(--accent-primary)" stroke-width="0.6" stroke-linecap="round" />
        <!-- Right side tendrils -->
        <path d="M13.5 12 L18 10.5" stroke="var(--accent-primary)" stroke-width="0.9" stroke-linecap="round" />
        <path d="M18 10.5 L21 9" stroke="var(--accent-primary)" stroke-width="0.7" stroke-linecap="round" />
        <path d="M18 10.5 L20 12.5" stroke="var(--accent-primary)" stroke-width="0.6" stroke-linecap="round" />
        <path d="M13.5 14 L17 15.5" stroke="var(--accent-primary)" stroke-width="0.7" stroke-linecap="round" />
        <!-- Left side tendrils -->
        <path d="M10.5 12 L6 13" stroke="var(--accent-primary)" stroke-width="0.9" stroke-linecap="round" />
        <path d="M6 13 L3 14" stroke="var(--accent-primary)" stroke-width="0.7" stroke-linecap="round" />
        <path d="M6 13 L4 11" stroke="var(--accent-primary)" stroke-width="0.6" stroke-linecap="round" />
        <path d="M10.5 10 L7 9" stroke="var(--accent-primary)" stroke-width="0.7" stroke-linecap="round" />
        <!-- Endpoint nodes -->
        <circle cx="7.5" cy="22" r="0.7" fill="var(--accent-primary)" opacity="0.5" />
        <circle cx="16.5" cy="22.5" r="0.7" fill="var(--accent-primary)" opacity="0.45" />
        <circle cx="12.5" cy="23" r="0.6" fill="var(--accent-primary)" opacity="0.4" />
        <circle cx="5" cy="23" r="0.5" fill="var(--accent-primary)" opacity="0.3" />
        <circle cx="19" cy="23.5" r="0.5" fill="var(--accent-primary)" opacity="0.3" />
        <circle cx="8.5" cy="3.5" r="0.7" fill="var(--accent-primary)" opacity="0.5" />
        <circle cx="16" cy="3" r="0.7" fill="var(--accent-primary)" opacity="0.45" />
        <circle cx="11" cy="2" r="0.6" fill="var(--accent-primary)" opacity="0.4" />
        <circle cx="6" cy="2" r="0.5" fill="var(--accent-primary)" opacity="0.3" />
        <circle cx="19" cy="1.5" r="0.5" fill="var(--accent-primary)" opacity="0.3" />
        <circle cx="21" cy="9" r="0.6" fill="var(--accent-primary)" opacity="0.35" />
        <circle cx="3" cy="14" r="0.6" fill="var(--accent-primary)" opacity="0.35" />
        <circle cx="5.5" cy="20.5" r="0.5" fill="var(--accent-primary)" opacity="0.3" />
        <circle cx="18" cy="20.5" r="0.5" fill="var(--accent-primary)" opacity="0.3" />
        <circle cx="7" cy="9" r="0.5" fill="var(--accent-primary)" opacity="0.3" />
        <circle cx="17" cy="15.5" r="0.5" fill="var(--accent-primary)" opacity="0.3" />
      </svg>
      <span><span style={`color: var(--text-primary);`}>bt</span><span>sr</span></span>
    </a>

    <!-- Nav links -->
    <ul class="hidden md:flex items-center gap-6 list-none" role="list">
      {
        nav.map(({ label, href }) => {
          const isActive =
            currentPath === href || currentPath.startsWith(href + "/");
          return (
            <li>
              <a
                href={href}
                class="no-underline hover:no-underline transition-colors"
                style={`
                  font-family: var(--font-sans);
                  font-weight: 500;
                  font-size: var(--text-sm);
                  color: ${isActive ? "var(--accent-primary)" : "var(--text-secondary)"};
                `}
                aria-current={isActive ? "page" : undefined}
              >
                {label}
              </a>
            </li>
          );
        })
      }
    </ul>

    <div class="flex items-center gap-4">
      <!-- Theme toggle -->
      <ThemeToggle client:load />

      <!-- Mobile menu button -->
      <button
        class="md:hidden p-2"
        style={`color: var(--text-secondary); background: none; border: none; cursor: pointer;`}
        aria-label="Open menu"
        aria-expanded="false"
        aria-controls="mobile-menu"
        id="mobile-menu-btn"
      >
        <svg
          width="24"
          height="24"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          aria-hidden="true"
        >
          <line class="hamburger-top" x1="3" y1="6" x2="21" y2="6"></line>
          <line class="hamburger-mid" x1="3" y1="12" x2="21" y2="12"></line>
          <line class="hamburger-bot" x1="3" y1="18" x2="21" y2="18"></line>
        </svg>
      </button>
    </div>
  </nav>

  <!-- Mobile nav panel -->
  <div
    id="mobile-menu"
    class="mobile-menu md:hidden"
    style={`border-color: var(--text-ghost);`}
  >
    <ul class="flex flex-col gap-4 list-none" role="list" style={`padding: 1.25rem 2.5rem 1.5rem;`}>
      {
        nav.map(({ label, href }) => {
          const isActive =
            currentPath === href || currentPath.startsWith(href + "/");
          return (
            <li>
              <a
                href={href}
                class="no-underline hover:no-underline"
                style={`
                  font-family: var(--font-sans);
                  font-weight: 500;
                  font-size: var(--text-base);
                  color: ${isActive ? "var(--accent-primary)" : "var(--text-secondary)"};
                `}
              >
                {label}
              </a>
            </li>
          );
        })
      }
    </ul>
  </div>
</header>

<style>
  .mobile-menu {
    overflow: hidden;
    max-height: 0;
    opacity: 0;
    border-top: 1px solid transparent;
    transition: max-height 0.25s ease, opacity 0.2s ease, border-color 0.2s ease;
  }

  .mobile-menu.open {
    max-height: 300px;
    opacity: 1;
    border-color: var(--text-ghost);
  }

  /* Hamburger → X animation */
  .hamburger-top,
  .hamburger-mid,
  .hamburger-bot {
    transition: transform 0.25s ease, opacity 0.15s ease;
    transform-origin: center;
  }

  [aria-expanded="true"] .hamburger-top {
    transform: translate(0, 6px) rotate(45deg);
  }

  [aria-expanded="true"] .hamburger-mid {
    opacity: 0;
  }

  [aria-expanded="true"] .hamburger-bot {
    transform: translate(0, -6px) rotate(-45deg);
  }

  @media (prefers-reduced-motion: reduce) {
    .mobile-menu {
      transition: none;
    }
    .hamburger-top,
    .hamburger-mid,
    .hamburger-bot {
      transition: none;
    }
  }
</style>

<script>
  const btn = document.getElementById("mobile-menu-btn");
  const menu = document.getElementById("mobile-menu");

  btn?.addEventListener("click", () => {
    const isOpen = menu?.classList.toggle("open");
    btn.setAttribute("aria-expanded", String(isOpen));
    btn.setAttribute("aria-label", isOpen ? "Close menu" : "Open menu");
  });
</script>
