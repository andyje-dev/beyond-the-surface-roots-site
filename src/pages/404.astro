---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="404" description="Page not found">
  <section
    class="flex flex-col items-center justify-center px-6"
    style={`min-height: 60vh; text-align: center;`}
  >
    <p
      style={`font-family: var(--font-mono); font-size: clamp(4rem, 10vw, 6rem); font-weight: 500; color: var(--text-ghost); line-height: 1; margin-bottom: 1.5rem;`}
    >
      404
    </p>
    <h1
      style={`font-size: clamp(1.25rem, 3vw, 1.75rem); margin-bottom: 1rem;`}
    >
      Nothing grows here yet
    </h1>
    <p
      style={`color: var(--text-secondary); font-size: var(--text-base); max-width: 420px; margin-bottom: 2.5rem; line-height: 1.7;`}
    >
      The page you're looking for doesn't exist, or maybe it just hasn't taken root...
    </p>
    <a
      href="/"
      class="inline-flex items-center gap-2 no-underline hover:no-underline"
      style={`
        font-family: var(--font-sans);
        font-weight: 500;
        font-size: var(--text-sm);
        color: var(--bg-void);
        background-color: var(--accent-primary);
        padding: 0.75rem 1.5rem;
        border-radius: var(--radius-md);
        transition: opacity 0.2s;
      `}
    >
      <span aria-hidden="true">&larr;</span>
      Back to surface
    </a>
  </section>
</BaseLayout>
